// --- Generated by Signaloid CLI ---

// Type definitions for the inputs that will be used in the Angular application.
export type InputType = "text" | "basic-slider" | "distribution-slider" | "multiple-choice";

export interface BaseInputConfig {
	id: string;
	name: string;
	argumentFlag: string;
	type: InputType;
}

export interface TextInputConfig extends BaseInputConfig {
	type: "text";
	initialValue: string;
}

export interface SliderConfig extends BaseInputConfig {
	type: "basic-slider" | "distribution-slider";
	min: number;
	max: number;
	step: number;
	initialValue: number;
	xAxisLabel: string;
	adjustWidth: boolean;
	isDistribution: boolean;
	initialDistribution?: [number, number][];
}

export interface MultipleChoiceConfig extends BaseInputConfig {
	type: "multiple-choice";
	options: { name: string; value: string }[];
	initialValue: string;
}

export type InputConfig = TextInputConfig | SliderConfig | MultipleChoiceConfig;

// The array of configured inputs, generated based on user prompts.
export const demoInputs: InputConfig[] = [
	<%# Loop over the 'inputs' array provided by the CLI. -%>
	<% inputs.forEach((input, index) => { -%>
	{
	<%# Use an if/else block to render the correct properties for each input type. -%>
	<% if (input.type === 'text-input') { -%>
		id: '<%= input.id %>',
		name: '<%= input.name %>',
		type: 'text',
		argumentFlag: '<%= input.argumentFlag %>',
		initialValue: '<%= input.initialValue %>'
	<% } else if (input.type === 'distribution-slider' || input.type === 'basic-slider') { -%>
		id: '<%= input.id %>',
		name: '<%= input.name %>',
		type: '<%= input.isDistribution ? "distribution-slider" : "basic-slider" %>',
		argumentFlag: '<%= input.argumentFlag %>',
		min: <%= input.min %>,
		max: <%= input.max %>,
		step: <%= input.step %>,
		initialValue: <%= input.initialValue %>,
		xAxisLabel: '<%= input.xAxisLabel %>',
		adjustWidth: <%= input.adjustWidth %>,
		isDistribution: <%= input.isDistribution %><% if (input.isDistribution) { %>,
		initialDistribution: <%- JSON.stringify(input.initialDistribution) %><% } %>
	<% } else if (input.type === 'multiple-choice') { -%>
		id: '<%= input.id %>',
		name: '<%= input.name %>',
		type: 'multiple-choice',
		argumentFlag: '<%= input.argumentFlag %>',
		initialValue: '<%= input.initialValue %>',
		options: [
			<% input.options.forEach((option, index) => { -%>
			{
				name: '<%= option.name %>',
				value: '<%= option.value %>'
			}<%- index < input.options.length - 1 ? ',' : '' %>
			<% }); -%>
		]
	<% } -%>
	}<%- index < inputs.length - 1 ? ',' : '' %>
	<% }); -%>
];